# ========== Next.js 前端 - 必需配置 ==========
PORT=3000
NODE_ENV=production

# LLM 模型配置 (DeepSeek/OpenAI 兼容接口)
MOCK_MODE=false
LLM_PROVIDER=openai_compatible
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_MS=30000
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TOP_P=1.0

# RAG 知识库服务配置
RAG_API_URL=http://localhost:8001
RAG_TOP_K=3

# ========== RAG 服务 (Python FastAPI) - 可选 ==========
# 如果在同一服务器运行 RAG 服务，需要配置以下项

# Embedding 模型 API 配置
OPENAI_API_KEY_EMBEDDING=your_embedding_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG 服务本地配置
EMBEDDING_PROVIDER=openai_compatible
RAG_SERVICE_PORT=8001
CHROMA_PERSIST_DIRECTORY=./rag-service/vector_store/chroma
KNOWLEDGE_PATH=./rag-service/knowledge
RAG_DEFAULT_TOP_K=3

# ========== 说明 ==========
# 1. 复制此文件为 .env 并填写真实值
# 2. 不要将真实密钥提交到版本控制
# 3. 生产环境建议将 NODE_ENV 设为 production
# 4. RAG 服务独立运行，也可以不使用（此时聊天功能可正常工作但无知识库）
