# ============================================================
# ENGINEERING AI ASSISTANT - Environment Configuration
# ============================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Fill in your OpenAI API key below
# 3. Run: pnpm install && pnpm dev
#
# For custom backend configuration, edit: /lib/api-config.ts
#
# ============================================================

# Mock mode switch (optional):
# - true  = force mock mode
# - false = force real API mode
# - empty = auto (no key => mock, has key => real)
MOCK_MODE=

# OpenAI API Key (required in real API mode)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional OpenAI-compatible base URL:
# - official OpenAI: leave empty
# - OpenRouter: https://openrouter.ai/api/v1
# - OneAPI/New API: https://your-gateway.example.com/v1
OPENAI_BASE_URL=

# ============================================================
# ALTERNATIVE: Use Mock Mode (No API key needed)
# ============================================================
# If you don't have an API key:
# 1. Set MOCK_MODE=true above
# 2. Keep OPENAI_API_KEY empty
# This will return simulated responses for testing.
