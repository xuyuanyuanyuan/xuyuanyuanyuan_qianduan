# =====================================================
# RAG Service 环境变量配置示例
# 
# 使用说明：
# 1. 复制本文件为 .env
# 2. 根据实际情况填写各项配置
# 3. 启动服务时会自动加载此文件
# =====================================================

# ==================== Embedding API 配置 ====================
# 使用 OpenAI 兼容的 embedding 服务

# API 提供商 (目前仅支持 openai_compatible)
EMBEDDING_PROVIDER=openai_compatible

# API 密钥 (必须填写)
# 如使用 OpenAI：https://platform.openai.com/api-keys
# 如使用其他兼容服务（DeepSeek、Alibaba 等）：填写对应密钥
OPENAI_API_KEY=your_api_key_here

# API 基础 URL (可选，默认使用 OpenAI 官方)
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# 阿里百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding 模型名称
# OpenAI: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
# DeepSeek: deepseek-chat
# 需要与所选 API 提供商支持的模型对应
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==================== 路径配置 ====================
# 所有路径都是相对路径，方便部署迁移

# PDF / OCR 文本知识库目录
KNOWLEDGE_PATH=./rag-service/knowledge

# Chroma 向量库持久化目录
CHROMA_PERSIST_DIRECTORY=./rag-service/vector_store/chroma

# OCR 输出目录（逐页 txt 会写到这里）
OCR_OUTPUT_DIR=./rag-service/knowledge/ocr_book

# ==================== RAG 服务配置 ====================

# 服务启动端口 (默认 8001)
RAG_SERVICE_PORT=8001

# 搜索返回结果数 (默认 3)
RAG_DEFAULT_TOP_K=3

# ==================== OCR 配置（可选） ====================

# OCR 默认起始页
OCR_DEFAULT_START_PAGE=1

# OCR 默认结束页（默认先只跑前 50 页）
OCR_DEFAULT_END_PAGE=50

# PaddleOCR 语言参数（中文文档建议 ch）
OCR_LANGUAGE=ch

# PDF 渲染缩放倍率，越大越清晰但越慢
OCR_ZOOM=2.0

# ==================== 高级配置（可选） ====================

# 本地 embedding 模型 (当前不支持，预留)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# 日志级别
LOG_LEVEL=INFO

# ==================== 使用示例 ====================
# 
# 例1: 使用 OpenAI 官方 embedding
# OPENAI_API_KEY=sk-proj-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# 例2: 使用 DeepSeek 兼容服务
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# 例3: 自定义路径
# KNOWLEDGE_PATH=../my-documents
# CHROMA_PERSIST_DIRECTORY=../my-vector-db
# OCR_OUTPUT_DIR=../my-documents/ocr_book
#
# =====================================================
