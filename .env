# Master mock switch:
# - true  = always use local mock data and never call a real API
# - false = use the provider selected by LLM_PROVIDER
MOCK_MODE=false


# Provider selection:
# - mock               = local mock response only
# - deepseek           = DeepSeek official OpenAI-compatible endpoint
# - openai_compatible  = OpenAI or any compatible gateway
LLM_PROVIDER=deepseek

# API key for the selected provider.
# Required when MOCK_MODE=false and provider is not mock.
LLM_API_KEY=

# Optional base URL override:
# - deepseek + empty            => https://api.deepseek.com/v1
# - openai_compatible + empty   => official OpenAI base URL
# - custom gateway example      => https://your-gateway.example.com/v1
LLM_BASE_URL=

# Optional model name:
# - deepseek default            => deepseek-chat
# - openai_compatible default   => gpt-4o-mini
LLM_MODEL=deepseek-chat

# Optional request timeout in milliseconds.
LLM_TIMEOUT_MS=30000

# Optional model parameters. Leave empty to use provider defaults.
LLM_TEMPERATURE=
LLM_MAX_TOKENS=
LLM_TOP_P=

# ============================================================
# QUICK SWITCH EXAMPLES
# ============================================================
#
# Mock:
# MOCK_MODE=true
# LLM_PROVIDER=mock
#
# DeepSeek:
# MOCK_MODE=false
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your-deepseek-key
# LLM_MODEL=deepseek-chat
#
# OpenAI-compatible:
# MOCK_MODE=false
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://your-openai-compatible-host/v1
# LLM_MODEL=gpt-4o-mini
