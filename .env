# ============================================================================
# cssc_agent 完整环境配置
# 包含：Next.js 前端 LLM 配置 + Python RAG 服务配置
# ============================================================================

# ==========================
# 【前端 LLM 配置】
# ==========================

# Mock 模式开关
# true  = 始终使用本地 mock 数据，不调用真实 API
# false = 使用 LLM_PROVIDER 选择的提供商
MOCK_MODE=false

# LLM 提供商选择
# - mock               = 本地 mock 响应
# - deepseek           = DeepSeek 官方兼容接口
# - openai_compatible  = OpenAI 或任何兼容网关
LLM_PROVIDER=deepseek

# LLM API 密钥（MOCK_MODE=false 时必须填写）
LLM_API_KEY=sk-ccf2ee02ad7b45bfb33896abe5520af1

# LLM 服务地址（可选，使用提供商默认值）
# - deepseek 默认    => https://api.deepseek.com/v1
# - openai 默认      => https://api.openai.com/v1
# - 自定义网关       => https://your-gateway.example.com/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# LLM 模型名称
# - deepseek 推荐    => deepseek-chat
# - openai 推荐      => gpt-4o-mini
LLM_MODEL=deepseek-chat

# LLM 请求超时（毫秒）
LLM_TIMEOUT_MS=30000

# LLM 生成参数（可选，留空使用默认）
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TOP_P=1.0

# ==========================
# 【RAG 前端接口配置】
# ==========================

# RAG 服务地址（必须与 RAG_SERVICE_HOST:RAG_SERVICE_PORT 对应）
RAG_API_URL=http://localhost:8001

# 单次检索返回结果数量
RAG_TOP_K=3

# ==========================
# 【Python RAG 服务配置】
# ==========================

# Embedding 服务提供商
# 仅支持 openai_compatible（OpenAI 兼容 API）
EMBEDDING_PROVIDER=openai_compatible

# Embedding API 密钥（必须填写）
OPENAI_API_KEY=sk-ccf2ee02ad7b45bfb33896abe5520af1

# Embedding 服务地址（与 LLM 可以相同或不同）
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Embedding 模型名称
OPENAI_EMBEDDING_MODEL=text-embedding

# 本地 embedding 模型（预留，暂不支持）
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG 服务启动端口
RAG_SERVICE_PORT=8001

# 向量库持久化目录（相对路径）
CHROMA_PERSIST_DIRECTORY=./rag-service/vector_store/chroma

# PDF 知识库目录（相对路径）
KNOWLEDGE_PATH=./rag-service/knowledge

# RAG 服务默认返回结果数
RAG_DEFAULT_TOP_K=3

# ==========================
# 【配置示例】
# ==========================
#
# 方案 1: DeepSeek (推荐中国用户)
# MOCK_MODE=false
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=sk-xxxxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-xxxxx (可同一个密钥)
# OPENAI_BASE_URL=https://api.deepseek.com/v1
#
# 方案 2: OpenAI
# MOCK_MODE=false
# LLM_API_KEY=sk-proj-xxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-proj-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# 方案 3: Mock 模式（无需填写密钥）
# MOCK_MODE=true
# LLM_PROVIDER=mock
